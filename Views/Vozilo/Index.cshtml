@model IEnumerable<VozniPark.Models.Vozilo>

@{
    ViewData["Title"] = "Pregled vozila";
}

<div class="container-fluid mt-4">
    <!-- Zaglavlje i dugme za kreiranje -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Lista vozila</h2>

        <div class="d-flex gap-2">
            <!-- NOVO DUGME ZA EXCEL -->
            <a asp-action="ExportToExcel" class="btn btn-success shadow-sm fw-bold">
                📊 Export u Excel
            </a>

            <!-- TVOJE POSTOJEĆE DUGME ZA DODAVANJE -->
            <a asp-action="Create" class="btn btn-primary shadow-sm">
                <b>+</b> Dodaj vozilo
            </a>
        </div>
    </div>

    <!-- FILTERI (Pretraga) -->
    <div class="card shadow-sm mb-4 border-0 bg-light">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label text-muted fw-bold small mb-1">Registracijska oznaka</label>
                    <input type="text" name="searchReg" class="form-control" placeholder="Npr. SA-100..." value="@ViewData["FilterReg"]" />
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted fw-bold small mb-1">Godina proizvodnje</label>
                    <input type="number" name="searchGodina" class="form-control" placeholder="Npr. 2022" value="@ViewData["FilterGodina"]" />
                </div>
                <div class="col-md-3">
                    <label class="form-label text-muted fw-bold small mb-1">Datum registracije (od)</label>
                    <input type="date" name="searchDatum" class="form-control" value="@ViewData["FilterDatum"]" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-grow-1 shadow-sm">
                        Filtriraj
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary shadow-sm">
                        Očisti
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Tabela -->
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.RegistracijskaOznaka)</th>
                    <th>@Html.DisplayNameFor(model => model.Marka)</th>
                    <th>@Html.DisplayNameFor(model => model.Model)</th>
                    <th>@Html.DisplayNameFor(model => model.GodinaProizvodnje)</th>
                    <th>@Html.DisplayNameFor(model => model.DatumRegistracije)</th>
                    <th>@Html.DisplayNameFor(model => model.Napomena)</th>
                    <th class="text-center">@Html.DisplayNameFor(model => model.Servisi)</th>
                    <th class="text-center">Akcije</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold">@Html.DisplayFor(modelItem => item.RegistracijskaOznaka)</td>
                        <td>@Html.DisplayFor(modelItem => item.Marka)</td>
                        <td>@Html.DisplayFor(modelItem => item.Model)</td>
                        <td>@Html.DisplayFor(modelItem => item.GodinaProizvodnje)</td>
                        <td>@item.DatumRegistracije.ToString("dd.MM.yyyy")</td>
                        <td class="text-muted">@Html.DisplayFor(modelItem => item.Napomena)</td>

                        <td class="text-center">
                            @if (item.Servisi != null && item.Servisi.Any())
                            {
                                <a asp-controller="Servis" asp-action="IndexByVozilo" asp-route-voziloId="@item.Id" class="text-decoration-none">
                                    <span class="badge bg-info text-dark fs-6 shadow-sm">
                                        @item.Servisi.Count() servisa
                                    </span>
                                </a>
                            }
                            else
                            {
                                <span class="badge bg-secondary opacity-75">Nema servisa</span>
                            }
                        </td>

                        <!-- Akcione tipke (Sada sa razmakom d-flex gap-2) -->
                        <td class="text-center">
                            <div class="d-flex gap-2 justify-content-center">
                                @if (User.IsInRole("USER"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm shadow-sm text-dark fw-bold">
                                        Uredi
                                    </a>
                                }

                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm shadow-sm">
                                    Detalji
                                </a>

                                @if (User.IsInRole("USER"))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm shadow-sm">
                                        Obriši
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>