@model VozniPark.Models.Vozilo

@{
    ViewData["Title"] = "Brisanje vozila";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <!-- Crveno upozorenje na vrhu -->
            <div class="alert alert-danger shadow-sm border-0 mb-4" role="alert">
                <h4 class="alert-heading fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Upozorenje!
                </h4>
                <p class="mb-0">
                    Da li ste sigurni da želite trajno obrisati vozilo <strong>@Model.Marka @Model.Model (@Model.RegistracijskaOznaka)</strong>?
                    Ova akcija se ne može poništiti.
                </p>
            </div>

            <!-- Kartica sa detaljima vozila -->
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-bottom p-3">
                    <h5 class="mb-0 text-dark"><i class="bi bi-info-circle me-2"></i> Detalji vozila</h5>
                </div>
                <div class="card-body p-4">
                    <dl class="row mb-0">
                        <dt class="col-sm-4 text-muted mb-2">@Html.DisplayNameFor(model => model.RegistracijskaOznaka)</dt>
                        <dd class="col-sm-8 fw-bold mb-2">@Html.DisplayFor(model => model.RegistracijskaOznaka)</dd>

                        <dt class="col-sm-4 text-muted mb-2">@Html.DisplayNameFor(model => model.Marka)</dt>
                        <dd class="col-sm-8 mb-2">@Html.DisplayFor(model => model.Marka)</dd>

                        <dt class="col-sm-4 text-muted mb-2">@Html.DisplayNameFor(model => model.Model)</dt>
                        <dd class="col-sm-8 mb-2">@Html.DisplayFor(model => model.Model)</dd>

                        <dt class="col-sm-4 text-muted mb-2">@Html.DisplayNameFor(model => model.GodinaProizvodnje)</dt>
                        <dd class="col-sm-8 mb-2">@Html.DisplayFor(model => model.GodinaProizvodnje)</dd>

                        <dt class="col-sm-4 text-muted mb-2">@Html.DisplayNameFor(model => model.DatumRegistracije)</dt>
                        <dd class="col-sm-8 mb-2">@Html.DisplayFor(model => model.DatumRegistracije)</dd>

                        <dt class="col-sm-4 text-muted mb-2">@Html.DisplayNameFor(model => model.Napomena)</dt>
                        <dd class="col-sm-8 mb-2">@Html.DisplayFor(model => model.Napomena)</dd>
                    </dl>
                </div>

                
                <div class="card-footer bg-light p-3">
                    <form asp-action="Delete" class="m-0 d-flex justify-content-end gap-2">
                        <input type="hidden" asp-for="Id" />
                        <a asp-action="Index" class="btn btn-outline-secondary">Nazad na listu</a>
                        <button type="submit" class="btn btn-danger px-4">
                            <i class="bi bi-trash3-fill me-1"></i> Obriši vozilo
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>