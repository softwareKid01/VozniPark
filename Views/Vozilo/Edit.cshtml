@model VozniPark.Models.Vozilo

@{
    ViewData["Title"] = "Uređivanje vozila";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-warning text-dark p-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i> Uređivanje podataka o vozilu</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                     
                        <input type="hidden" asp-for="Id" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="RegistracijskaOznaka" class="form-label fw-bold"></label>
                                <input asp-for="RegistracijskaOznaka" class="form-control" />
                                <span asp-validation-for="RegistracijskaOznaka" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DatumRegistracije" class="form-label fw-bold"></label>
                                <input asp-for="DatumRegistracije" class="form-control" type="date" />
                                <span asp-validation-for="DatumRegistracije" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="Marka" class="form-label fw-bold"></label>
                                <input asp-for="Marka" class="form-control" />
                                <span asp-validation-for="Marka" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="Model" class="form-label fw-bold"></label>
                                <input asp-for="Model" class="form-control" />
                                <span asp-validation-for="Model" class="text-danger"></span>
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="GodinaProizvodnje" class="form-label fw-bold"></label>
                                <select asp-for="GodinaProizvodnje" class="form-select">
                                    @{
                                        int startYear = 1990;
                                        int endYear = DateTime.Now.Year;

                                        for (int i = endYear; i >= startYear; i--)
                                        {
                                            <option value="@i">@i</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="GodinaProizvodnje" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Napomena" class="form-label fw-bold"></label>
                            <textarea asp-for="Napomena" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Napomena" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary me-md-2">Nazad na listu</a>
                            <button type="submit" class="btn btn-warning px-4 fw-bold">
                                <i class="bi bi-save me-1"></i> Sačuvaj izmjene
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}