@{
    ViewData["Title"] = "Kontrolna tabla";

    // Preuzimamo podatke iz ViewBag-a i kastamo ih u liste vozila
    var kriticneReg = ViewBag.KriticneRegistracije as IEnumerable<VozniPark.Models.Vozilo>;
    var kriticniServisi = ViewBag.KriticniServisi as IEnumerable<VozniPark.Models.Vozilo>;

    int brojReg = ViewBag.BrojKriticnihRegistracija ?? 0;
    int brojServisa = ViewBag.BrojKriticnihServisa ?? 0;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Kontrolna tabla (Dashboard)</h2>
    </div>

    <!-- KARTICE SA BROJAČIMA -->
    <div class="row mb-5">
        <!-- Kartica za Registracije -->
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-0 @(brojReg > 0 ? "bg-danger text-white" : "bg-success text-white") h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-2 opacity-75">Upozorenja za registraciju</h6>
                        <h2 class="display-5 fw-bold mb-0">@brojReg</h2>
                    </div>
                    <div>
                        <i class="fs-1 bi bi-card-checklist opacity-50"></i> <!-- Ako imaš bootstrap ikone -->
                    </div>
                </div>
                <div class="card-footer border-0 bg-dark bg-opacity-10 text-white">
                    <small>Vozila sa isteklom ili uskoro isteklom registracijom</small>
                </div>
            </div>
        </div>

        <!-- Kartica za Servise -->
        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-0 @(brojServisa > 0 ? "bg-warning text-dark" : "bg-success text-white") h-100">
                <div class="card-body d-flex align-items-center justify-content-between">
                    <div>
                        <h6 class="text-uppercase fw-bold mb-2 opacity-75">Upozorenja za servis</h6>
                        <h2 class="display-5 fw-bold mb-0">@brojServisa</h2>
                    </div>
                    <div>
                        <i class="fs-1 bi bi-tools opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer border-0 bg-dark bg-opacity-10 @(brojServisa > 0 ? "text-dark" : "text-white")">
                    <small>Vozila kojima je istekao ili uskoro ističe servisni interval</small>
                </div>
            </div>
        </div>
    </div>

    <!-- TABELE SA DETALJIMA -->
    <div class="row">

        <!-- Tabela: Istekle registracije -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom border-danger border-3 p-3">
                    <h5 class="mb-0 fw-bold text-danger">Potrebna registracija</h5>
                </div>
                <div class="card-body p-0">
                    @if (kriticneReg != null && kriticneReg.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Vozilo</th>
                                        <th>Datum isteka</th>
                                        <th>Status</th>
                                        <th>Akcija</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in kriticneReg)
                                    {
                                        <tr>
                                            <td class="fw-bold">@v.RegistracijskaOznaka<br /><small class="text-muted fw-normal">@v.Marka @v.Model</small></td>
                                            <td>@v.DatumIstekaRegistracije.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                @if (v.RegistracijaIstekla)
                                                {
                                                    <span class="badge bg-danger">Isteklo</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">Ističe uskoro</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="Vozilo" asp-action="Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-danger shadow-sm">Detalji</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            <h6 class="mb-0">Sva vozila su uredno registrovana.</h6>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Tabela: Potrebni servisi -->
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom border-warning border-3 p-3">
                    <h5 class="mb-0 fw-bold text-warning text-dark">Potreban servis</h5>
                </div>
                <div class="card-body p-0">
                    @if (kriticniServisi != null && kriticniServisi.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Vozilo</th>
                                        <th>Krajnji rok</th>
                                        <th>Status</th>
                                        <th>Akcija</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in kriticniServisi)
                                    {
                                        <tr>
                                            <td class="fw-bold">@v.RegistracijskaOznaka<br /><small class="text-muted fw-normal">@v.Marka @v.Model</small></td>
                                            <td>@(v.KrajnjiRokZaServis?.ToString("dd.MM.yyyy") ?? "Nema podataka")</td>
                                            <td>
                                                @if (v.ServisIstekao)
                                                {
                                                    <span class="badge bg-danger">Probijen rok</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">Uskoro dospijeva</span>
                                                }
                                            </td>
                                            <td>
                                                <a asp-controller="Vozilo" asp-action="Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-warning text-dark fw-bold shadow-sm">Detalji</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-4 text-center text-muted">
                            <h6 class="mb-0">Svim vozilima je uredno odrađen servis.</h6>
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>
</div>