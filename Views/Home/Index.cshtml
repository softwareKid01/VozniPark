@{
    ViewData["Title"] = "Početna";
}

<style>
    
    .hero-section {
        
        background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.7)), url('/images/hero-bg.jpg') no-repeat center center;
        background-size: cover;
        height: 75vh; 
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-align: center;
        margin-top: 20px;
    }
</style>

<div class="container">
    <div class="hero-section shadow-lg">
        <div class="p-4">
            <h1 class="display-3 fw-bold mb-3">Sistem "VozniPark"</h1>
            <p class="lead mb-5 fs-4">
                Profesionalno upravljanje vozilima, praćenje servisa i kontrola registracija na jednom mjestu.
            </p>

            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <a asp-controller="Vozilo" asp-action="Dashboard" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-sm fw-bold fs-5">
                    <i class="bi bi-speedometer2 me-2"></i> Otvori Dashboard
                </a>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg px-5 py-3 rounded-pill shadow-sm fw-bold fs-5">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Prijavite se
                </a>
            }
        </div>
    </div>
</div>