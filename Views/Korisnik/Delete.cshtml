@model VozniPark.Models.Korisnik
@{
    ViewData["Title"] = "Obriši korisnika";
}

<div class="container mt-4 w-50">
    <div class="card shadow-sm border-danger p-4 text-center">
        <h3 class="text-danger fw-bold mb-3">Da li ste sigurni?</h3>
        <p class="fs-5">Brisanjem trajno uklanjate korisnika: <br /> <strong>@Model.UserName</strong></p>

        <form asp-action="Delete" method="post" class="mt-4 d-flex justify-content-center gap-3">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="btn btn-outline-secondary w-25">Odustani</a>
            <button type="submit" class="btn btn-danger fw-bold w-25">Obriši</button>
        </form>
    </div>
</div>