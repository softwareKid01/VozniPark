@model IEnumerable<VozniPark.Models.Korisnik>

@{
    ViewData["Title"] = "Upravljanje korisnicima";
}

<div class="container-fluid mt-4">
    <!-- Zaglavlje -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Upravljanje korisnicima</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <b>+</b> Dodaj novog korisnika
        </a>
    </div>

    <!-- Prikaz u karticama (5 kartica u redu na velikim ekranima) -->
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-5 g-4 mb-4">
        @if (Model != null && Model.Any())
        {
            @foreach (var user in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 text-center transition-hover">
                        <!-- Slika korisnika (Pravatar API) -->
                        <div class="card-header bg-transparent border-0 pt-4 pb-0">
                            <!-- Pravatar koristi ID korisnika da bi slika uvijek bila ista za tog korisnika -->
                            <img src="https://i.pravatar.cc/150?u=@user.Id" class="rounded-circle shadow" alt="Slika korisnika" width="90" height="90" style="object-fit: cover;">
                        </div>

                        <div class="card-body">
                            <!-- Prikaz imena ili emaila u zavisnosti šta imaš u modelu -->
                            <h5 class="card-title fw-bold text-dark mb-1 text-truncate">
                                <!-- Ako imaš Ime i Prezime u modelu, ostavi ovako, inače stavi @user.UserName -->
                                @user.UserName
                            </h5>
                            <p class="card-text text-muted small mb-3 text-truncate" title="@user.Email">
                                @user.Email
                            </p>

                            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill mb-2">
                                Zaposlenik
                            </span>
                        </div>

                        <div class="card-footer bg-white border-top-0 pb-3">
                            <div class="d-flex gap-2 justify-content-center">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-warning text-dark fw-bold w-100 shadow-sm">Uredi</a>
                                <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-outline-danger w-100 shadow-sm">Obriši</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 w-100">
                <h5 class="text-muted">Trenutno nema korisnika u sistemu.</h5>
            </div>
        }
    </div>

    <!-- Paginacija (prikazuje se samo ako ima više od 1 stranice) -->
    @if (ViewBag.TotalPages > 1)
    {
        <nav aria-label="Navigacija po stranicama" class="mt-4">
            <ul class="pagination justify-content-center shadow-sm">
                <!-- Dugme Prethodna -->
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link text-primary" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">
                        &laquo; Nazad
                    </a>
                </li>

                <!-- Brojevi stranica -->
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link @(i == ViewBag.CurrentPage ? "bg-primary border-primary" : "text-primary")" asp-action="Index" asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <!-- Dugme Sljedeća -->
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link text-primary" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">
                        Naprijed &raquo;
                    </a>
                </li>
            </ul>
        </nav>
    }
</div>