@model VozniPark.ViewModels.KorisnikCreateViewModel
@{
    ViewData["Title"] = "Dodaj korisnika";
}

<div class="container mt-4 w-50">
    <h3 class="text-primary fw-bold mb-4">Dodaj novog korisnika</h3>
    <form asp-action="Create" class="card shadow-sm border-0 p-4">
        <div asp-validation-summary="All" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label fw-bold"></label>
            <input asp-for="Email" class="form-control" placeholder="ime@voznipark.ba" />
        </div>
        <div class="mb-3">
            <label asp-for="Ime" class="form-label fw-bold"></label>
            <input asp-for="Ime" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Prezime" class="form-label fw-bold"></label>
            <input asp-for="Prezime" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Lozinka" class="form-label fw-bold"></label>
            <input asp-for="Lozinka" class="form-control" type="password" />
        </div>
        <div class="mb-4">
            <label asp-for="Uloga" class="form-label fw-bold"></label>
            <select asp-for="Uloga" asp-items="ViewBag.Uloge" class="form-select"></select>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
            <button type="submit" class="btn btn-success fw-bold">Kreiraj korisnika</button>
        </div>
    </form>
</div>