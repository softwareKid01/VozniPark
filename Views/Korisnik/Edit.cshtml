@model VozniPark.ViewModels.KorisnikEditViewModel
@{
    ViewData["Title"] = "Uredi korisnika";
}

<div class="container mt-4 w-50">
    <h3 class="text-warning fw-bold mb-4">Uredi korisnika</h3>
    <form asp-action="Edit" class="card shadow-sm border-0 p-4">
        <div asp-validation-summary="All" class="text-danger"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="Email" class="form-label fw-bold"></label>
            <input asp-for="Email" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Ime" class="form-label fw-bold"></label>
            <input asp-for="Ime" class="form-control" />
        </div>
        <div class="mb-3">
            <label asp-for="Prezime" class="form-label fw-bold"></label>
            <input asp-for="Prezime" class="form-control" />
        </div>
        <div class="mb-4">
            <label asp-for="Uloga" class="form-label fw-bold"></label>
            <select asp-for="Uloga" asp-items="ViewBag.Uloge" class="form-select"></select>
        </div>

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
            <button type="submit" class="btn btn-warning fw-bold">Sačuvaj izmjene</button>
        </div>
    </form>
</div>