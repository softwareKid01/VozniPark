@{
    ViewData["Title"] = "Prijava u sistem";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-lg">
            <div class="card-header bg-primary text-white text-center py-3">
                <h3 class="font-weight-light my-2">@ViewData["Title"]</h3>
            </div>
            <div class="card-body p-4">
                <form asp-controller="Account" asp-action="Login" asp-route-returnurl="@Context.Request.Query["ReturnUrl"]" method="post">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <div class="form-floating mb-3">
                        <input name="email" class="form-control" id="inputEmail" type="email" placeholder="name@example.com" required />
                        <label for="inputEmail">Email adresa</label>
                    </div>

                    <div class="form-floating mb-3">
                        <input name="password" class="form-control" id="inputPassword" type="password" placeholder="Lozinka" required />
                        <label for="inputPassword">Lozinka</label>
                    </div>

                    

                   
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        

                        
                        <div class="d-flex gap-3">
                            <a asp-controller="Account" asp-action="Register" class="text-decoration-none small fw-bold">Registruj se</a>
                            <a href="https://github.com/tvoj-profil" target="_blank" class="text-decoration-none small">Zaprati me 🔗</a>
                        </div>
                    </div>

                   
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary btn-lg">Prijavi se</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>